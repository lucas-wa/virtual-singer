# ============================================================================
# Modelo de configuração do job SLURM.  Copie para slurm/.env e edite:
#     cp slurm/.env.example slurm/.env
#
# Formato: KEY=valor  (sem "export", sem espaços ao redor do "=", sem aspas
# obrigatórias). O .sbatch faz `set -a; source slurm/.env`, então TODA variável
# aqui vira variável de ambiente exportada e o Singularity a injeta no container.
#
# Tudo é OPCIONAL: sem .env, o job roda com os defaults (demo + VocalSet female1 + DSP).
# NÃO commite o slurm/.env (já está no .gitignore).
# ============================================================================

# ---- Infraestrutura (onde rodar) -------------------------------------------
CONTAINER_IMAGE=/raid/user_lucasalves/images/vllm-openai_nightly-2e36cdbe2b4bff4370a02105fdfbdd015d6ec4e8.sif
HOST_RAID=/raid/user_lucasalves
PROJECT_SUBDIR=ufg/pav/virtual-singer

# Container py3.10 para AVATAR (SadTalker) — imagem runtime basta:
# AVATAR_CONTAINER_IMAGE=/raid/user_lucasalves/images/pytorch_2.2_cu121_py310.sif
# Container py3.10 com COMPILADOR (gcc) para YINGMUSIC — precisa da imagem -devel:
#   singularity pull /raid/user_lucasalves/images/pytorch_2.2_cu121_py310_devel.sif \
#       docker://pytorch/pytorch:2.2.2-cuda12.1-cudnn8-devel
# YING_CONTAINER_IMAGE=/raid/user_lucasalves/images/pytorch_2.2_cu121_py310_devel.sif

# ---- Hugging Face (opcional) -----------------------------------------------
# Evita avisos de rate-limit nos downloads públicos.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# ---- Cache de pacotes ------------------------------------------------------
# As deps são instaladas só na 1ª vez e ficam em /work/.home/.local (persistente).
# Descomente para FORÇAR reinstalação (ex.: ao mudar requirements):
# REINSTALL=1

# ---- Experimento (o que sintetizar) ----------------------------------------
SONG=demo                        # pasta em data/songs/ (demo já vem pronta)
VOICE_NAME=vocalset_female1      # nome do modelo de voz
VOICE_SOURCE=vocalset:female1    # vocalset:<singer> | path:/work/.../wavs | existing
ENGINE=dsp                       # dsp (sempre roda) | diffsinger (precisa voicebank EN)
EPOCHS=100                       # épocas de treino do RVC
AVATAR_IMAGE=                    # vazio = só áudio | synthetic = rosto gerado | /caminho/img.jpg
# OUT=out/meu_resultado.wav      # default: out/<VOICE_NAME>_<SONG>.wav
